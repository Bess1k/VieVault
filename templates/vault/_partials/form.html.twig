{# Liste des fichiers existants (avant le formulaire principal) #}
{% if form.vars.data.id and form.vars.data.files|length > 0 %}
    <div class="card card-white mb-4">
        <div class="card-body">
            <p class="text-uppercase text-muted small fw-bold mb-3" style="letter-spacing: 1px;">Fichiers existants</p>
            {% for file in form.vars.data.files %}
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <a href="{{ asset('uploads/vault/' ~ file.filename) }}" target="_blank" class="text-decoration-none">
                        &#128196; {{ file.originalName }}
                    </a>
                    <form method="post" action="{{ path('app_vault_file_delete', {id: file.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer ce fichier ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_file' ~ file.id) }}">
                        <button type="submit" class="btn btn-link btn-sm p-0 small text-danger text-decoration-none">Supprimer</button>
                    </form>
                </div>
            {% endfor %}
        </div>
    </div>
{% endif %}

{# Formulaire réutilisable pour ajout et modification d'un élément du coffre #}
<div class="card card-white">
    <div class="card-body">
        {{ form_start(form) }}

            {# Section : Informations de l'élément #}
            <p class="text-uppercase text-muted small fw-bold mb-3" style="letter-spacing: 1px;">Informations de l'élément</p>
            <div class="row">
                <div class="col-md-8 mb-3">
                    {{ form_row(form.title) }}
                </div>
                <div class="col-md-4 mb-3">
                    {{ form_row(form.type) }}
                </div>
            </div>
            {{ form_row(form.content) }}

            {# Section : Héritage #}
            <hr class="my-4">
            <p class="text-uppercase text-muted small fw-bold mb-3" style="letter-spacing: 1px;">Héritage</p>
            {{ form_row(form.isHeritage) }}
            <div id="beneficiary-field" style="display: none;">
                {{ form_row(form.beneficiary) }}
            </div>

            {# Section : Fichiers #}
            <hr class="my-4">
            <p class="text-uppercase text-muted small fw-bold mb-3" style="letter-spacing: 1px;">Fichiers joints</p>
            {{ form_row(form.uploadedFile) }}
            <p class="text-muted small">Formats acceptés : PDF, JPG, PNG, TXT — max 5 Mo</p>

            {# Boutons #}
            <div class="d-flex gap-2 mt-4 pt-3 border-top">
                <button type="submit" class="btn btn-primary">Enregistrer</button>
                <a href="{{ path('app_vault') }}" class="btn btn-outline-secondary">Annuler</a>
            </div>

        {{ form_end(form) }}
    </div>
</div>

{# Script pour afficher/masquer la liste des bénéficiaires #}
<script>
    const checkbox = document.getElementById('{{ form.isHeritage.vars.id }}');
    const beneficiaryField = document.getElementById('beneficiary-field');
    function toggleBeneficiary() {
        beneficiaryField.style.display = checkbox.checked ? 'block' : 'none';
    }
    toggleBeneficiary();
    checkbox.addEventListener('change', toggleBeneficiary);
</script>