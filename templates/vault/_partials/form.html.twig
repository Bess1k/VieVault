{# Formulaire réutilisable pour ajout et modification d'un élément du coffre #}
{{ form_start(form) }}
    {{ form_row(form.title) }}
    {{ form_row(form.type) }}
    {{ form_row(form.content) }}
    {{ form_row(form.isHeritage) }}

    {# Liste des bénéficiaires, masquée par défaut si l'élément n'est pas transmissible #}
    <div id="beneficiary-field" style="display: none;">
        {{ form_row(form.beneficiary) }}
    </div>

    {# Upload de nouveaux fichiers #}
    {{ form_row(form.uploadedFile) }}

    <button type="submit" class="btn btn-primary mt-3">Enregistrer</button>
    <a href="{{ path('app_vault') }}" class="btn btn-secondary mt-3">Annuler</a>
{{ form_end(form) }}

{# Liste des fichiers existants #}
{% if form.vars.data.id and form.vars.data.files|length > 0 %}
    <div class="mb-3">
        <label class="form-label fw-bold">Fichiers existants</label>
        {% for file in form.vars.data.files %}
            <div class="d-flex align-items-center mb-1">
                <a href="{{ asset('uploads/vault/' ~ file.filename) }}" target="_blank" class="me-2">
                    {{ file.originalName }}
                </a>
                <form method="post" action="{{ path('app_vault_file_delete', {id: file.id}) }}" class="d-inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce fichier ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_file' ~ file.id) }}">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                </form>
            </div>
        {% endfor %}
    </div>
    <hr>
{% endif %}

{# Script pour afficher/masquer la liste des bénéficiaires #}
<script>
    const checkbox = document.getElementById('{{ form.isHeritage.vars.id }}');
    const beneficiaryField = document.getElementById('beneficiary-field');

    function toggleBeneficiary() {
        beneficiaryField.style.display = checkbox.checked ? 'block' : 'none';
    }

    toggleBeneficiary();
    checkbox.addEventListener('change', toggleBeneficiary);
</script>