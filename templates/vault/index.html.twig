{% extends 'base.html.twig' %}

{% block title %}Mon coffre{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>Mon coffre</h1>
            <p class="text-muted mb-0">{{ vaultElements|length }} élément(s) stocké(s)</p>
        </div>
        <a href="{{ path('app_vault_new') }}" class="btn btn-primary">+ Ajouter un élément</a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {# Barre de recherche et filtre par type #}
    <form method="GET" class="mb-4">
        <div class="row g-2">
            <div class="col-md-6">
                <input type="text" class="form-control" name="search" 
                    placeholder="Rechercher par titre..." value="{{ search }}">
            </div>
            <div class="col-md-4">
                <select name="type" class="form-select">
                    <option value="">Tous les types</option>
                    <option value="CODE" {{ selectedType == 'CODE' ? 'selected' }}>Code</option>
                    <option value="DOCUMENT" {{ selectedType == 'DOCUMENT' ? 'selected' }}>Document</option>
                    <option value="CRYPTO" {{ selectedType == 'CRYPTO' ? 'selected' }}>Cryptomonnaie</option>
                    <option value="MOT_DE_PASSE" {{ selectedType == 'MOT_DE_PASSE' ? 'selected' }}>Mot de passe</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-secondary w-100">Rechercher</button>
            </div>
        </div>
    </form>

    {% if vaultElements|length == 0 %}
        <div class="alert alert-info">
            {% if search or selectedType %}
                Aucun élément trouvé pour cette recherche.
                <a href="{{ path('app_vault') }}">Réinitialiser</a>
            {% else %}
                Votre coffre est vide. Commencez par ajouter un élément.
            {% endif %}
        </div>
    {% else %}
        <div class="row g-4">
            {% for element in vaultElements %}
                <div class="col-md-4">
                    <div class="card card-hover card-white h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0 fw-bolder">{{ element.title }}</h5>
                                <span class="text-muted small border rounded px-2 py-1">{{ element.type }}</span>
                            </div>

                            {% if element.isHeritage %}
                                <p class="small mb-2" style="color: #0d6efd;">
                                    Héritage
                                    {% if element.beneficiary %}
                                        → {{ element.beneficiary.firstname }} {{ element.beneficiary.lastname }}
                                    {% endif %}
                                </p>
                            {% endif %}

                            {% if element.files|length > 0 %}
                                <p class="small text-muted mb-2">
                                    {% for file in element.files %}
                                        <a href="{{ asset('uploads/vault/' ~ file.filename) }}" target="_blank" class="text-muted text-decoration-underline me-1">
                                            {{ file.originalName }}
                                        </a>
                                    {% endfor %}
                                </p>
                            {% endif %}

                            <p class="text-muted small mb-0">
                                {{ element.createdAt|date('d/m/Y à H:i') }}
                                {% if element.updatedAt %}
                                    · modifié le {{ element.updatedAt|date('d/m/Y à H:i') }}
                                {% endif %}
                            </p>
                        </div>
                        <div class="card-footer bg-transparent">
                            <a href="{{ path('app_vault_edit', {id: element.id}) }}" class="small" style="color: #0d6efd;">Modifier</a>
                            <span class="text-muted mx-1">|</span>
                            <form method="post" action="{{ path('app_vault_delete', {id: element.id}) }}" class="d-inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet élément ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ element.id) }}">
                                <button type="submit" class="btn btn-link btn-sm p-0 small text-danger text-decoration-none">Supprimer</button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}