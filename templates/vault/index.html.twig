{% extends 'base.html.twig' %}

{% block title %}Mon coffre{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Mon coffre</h1>
        <a href="{{ path('app_vault_new') }}" class="btn btn-primary">+ Ajouter un élément</a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {# Barre de recherche et filtre par type (méthode GET comme le prof) #}
    <form method="GET" class="mb-4">
        <div class="row g-2">
            <div class="col-md-6">
                <input type="text" class="form-control" name="search" 
                    placeholder="Rechercher par titre..." value="{{ search }}">
            </div>
            <div class="col-md-4">
                <select name="type" class="form-select">
                    <option value="">Tous les types</option>
                    <option value="CODE" {{ selectedType == 'CODE' ? 'selected' }}>Code</option>
                    <option value="DOCUMENT" {{ selectedType == 'DOCUMENT' ? 'selected' }}>Document</option>
                    <option value="CRYPTO" {{ selectedType == 'CRYPTO' ? 'selected' }}>Cryptomonnaie</option>
                    <option value="MOT_DE_PASSE" {{ selectedType == 'MOT_DE_PASSE' ? 'selected' }}>Mot de passe</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-secondary w-100">Rechercher</button>
            </div>
        </div>
    </form>

    {% if vaultElements|length == 0 %}
        <div class="alert alert-info">
            {% if search or selectedType %}
                Aucun élément trouvé pour cette recherche.
                <a href="{{ path('app_vault') }}">Réinitialiser</a>
            {% else %}
                Votre coffre est vide. Commencez par ajouter un élément.
            {% endif %}
        </div>
    {% else %}
        <div class="row">
            {% for element in vaultElements %}
                <div class="col-md-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">{{ element.title }}</h5>
                            <span class="badge bg-primary">{{ element.type }}</span>
                            {% if element.isHeritage %}
                                <span class="badge bg-warning">Héritage</span>
                                {% if element.beneficiary %}
                                    <span class="badge bg-info">→ {{ element.beneficiary.firstname }} {{ element.beneficiary.lastname }}</span>
                                {% endif %}
                            {% endif %}
                            {% if element.files|length > 0 %}
                                <p class="mt-1">
                                    {% for file in element.files %}
                                        <a href="{{ asset('uploads/vault/' ~ file.filename) }}" target="_blank" class="badge bg-secondary me-1">
                                            {{ file.originalName }}
                                        </a>
                                    {% endfor %}
                                </p>
                            {% endif %}
                            <p class="card-text mt-2 text-muted">
                                Ajouté le {{ element.createdAt|date('d/m/Y à H:i') }}
                                {% if element.updatedAt %}
                                    <br>Modifié le {{ element.updatedAt|date('d/m/Y à H:i') }}
                                {% endif %}
                            </p>
                        </div>
                        <div class="card-footer d-flex justify-content-between">
                            <a href="{{ path('app_vault_edit', {id: element.id}) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                            <form method="post" action="{{ path('app_vault_delete', {id: element.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet élément ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ element.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}