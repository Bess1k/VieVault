{% extends 'base.html.twig' %}

{% block title %}Mon coffre{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Mon coffre</h1>
        <a href="#" class="btn btn-primary">+ Ajouter un élément</a>
    </div>

    <div class="row">
        {% for element in fakeElements %}
            <div class="col-md-4 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">{{ element.title }}</h5>
                        <span class="badge bg-primary">{{ element.type }}</span>
                        <p class="card-text mt-2 text-muted">
                            Ajouté le {{ element.createdAt|date('d/m/Y à H:i') }}
                        </p>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}