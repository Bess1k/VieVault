{% extends 'base.html.twig' %}

{% block title %}Espace Notaire{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Espace Notaire — Demandes d'héritage</h1>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% if demandes|length == 0 %}
        <div class="alert alert-info">Aucune demande en attente.</div>
    {% else %}
        {% for b in demandes %}
            <div class="card mb-3">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h5 class="card-title">{{ b.firstname }} {{ b.lastname }}</h5>
                            <p><strong>Email :</strong> {{ b.email }}</p>
                            {% if b.birthDate %}
                                <p><strong>Date de naissance :</strong> {{ b.birthDate|date('d/m/Y') }}</p>
                            {% endif %}
                            {% if b.birthPlace %}
                                <p><strong>Lieu de naissance :</strong> {{ b.birthPlace }}</p>
                            {% endif %}
                        </div>
                        <div class="col-md-6">
                            <p><strong>Propriétaire du coffre :</strong> {{ b.createdBy.firstname }} {{ b.createdBy.lastname }}</p>
                            <p><strong>Justificatif :</strong>
                                <a href="#" class="text-primary">Voir le document</a>
                            </p>
                            <p><strong>Statut :</strong>
                                <span class="badge bg-warning">En attente</span>
                            </p>
                        </div>
                    </div>
                    <div class="mt-3">
                        {# Bouton Approuver #}
                        <form method="post" action="{{ path('app_notaire_approve', {id: b.id}) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('approve' ~ b.id) }}">
                            <button type="submit" class="btn btn-success" onclick="return confirm('Confirmer l\'approbation ?');">
                                Approuver
                            </button>
                        </form>
                        {# Bouton Refuser #}
                        <form method="post" action="{{ path('app_notaire_reject', {id: b.id}) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ b.id) }}">
                            <button type="submit" class="btn btn-danger" onclick="return confirm('Confirmer le refus ?');">
                                Refuser
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        {% endfor %}
    {% endif %}
</div>
{% endblock %}