{% extends 'base.html.twig' %}

{% block title %}VieVault — Coffre-fort numérique & héritage{% endblock %}

{% block body %}
{# Section Hero #}
<div class="d-flex align-items-center justify-content-center text-center hero-section">
    <div class="container">
        <img src="{{ asset('images/logo-nb.png') }}" alt="VieVault" height="130" class="mb-4">
        <h1 class="display-4 fw-bold hero-title mb-3">Sécurisez aujourd'hui,<br>transmettez demain.</h1>
        <p class="lead mb-4 text-muted">
            Votre coffre-fort numérique personnel pour protéger vos données<br class="d-none d-md-block">
            et organiser leur transmission à vos proches.
        </p>
        {% if not app.user %}
            <a href="{{ path('app_register') }}" class="btn btn-primary btn-lg me-2">S'inscrire</a>
            <a href="{{ path('app_login') }}" class="btn btn-outline-primary btn-lg">Se connecter</a>
        {% else %}
            <a href="{{ path('app_dashboard') }}" class="btn btn-primary btn-lg">Accéder à mon coffre</a>
        {% endif %}
    </div>
</div>

{# Section Fonctionnalités #}
<div class="container py-5 my-5">
    <h2 class="text-center mb-5">Comment ça fonctionne ?</h2>
    <div class="row g-4">
        {# Carte 1 : Coffre-fort #}
        <div class="col-md-4">
            <div class="card h-100 text-center border-0 shadow-sm card-hover">
                <div class="card-body">
                    <img src="{{ asset('images/coffre.png') }}" alt="Coffre-fort" height="80" class="mb-3">
                    <h5 class="card-title">Coffre-fort sécurisé</h5>
                    <p class="card-text text-muted">
                        Stockez vos mots de passe, codes, documents et clés de cryptomonnaies dans un espace hautement sécurisé.
                    </p>
                </div>
            </div>
        </div>

        {# Carte 2 : Héritage #}
        <div class="col-md-4">
            <div class="card h-100 text-center border-0 shadow-sm card-hover">
                <div class="card-body">
                    <img src="{{ asset('images/heritage.png') }}" alt="Heritage" height="80" class="mb-3">
                    <h5 class="card-title">Héritage numérique</h5>
                    <p class="card-text text-muted">
                        Désignez des bénéficiaires pour chaque élément.
                        En cas d'inactivité prolongée, vos données sont transmises en toute sécurité.
                    </p>
                </div>
            </div>
        </div>

        {# Carte 3 : Sécurité #}
        <div class="col-md-4">
            <div class="card h-100 text-center border-0 shadow-sm card-hover">
                <div class="card-body">
                    <img src="{{ asset('images/protection.png') }}" alt="Protection" height="80" class="mb-3">
                    <h5 class="card-title">Protection avancée</h5>
                    <p class="card-text text-muted">
                        Connexion d'urgence discrète, pause vacances, historique des actions et validation légale pour une sécurité maximale.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

{# Section Comment ça marche  #}
<div class="section-marine py-5 my-5 text-white">
    <div class="container">
        <h2 class="text-center mb-5">En 4 étapes simples</h2>
        <div class="row g-4">
            <div class="col-md-3 text-center">
                <div class="display-5 fw-bold mb-2 numero-etape">1</div>
                <h6 class="fw-bold">Créez votre compte</h6>
                <p class="small opacity-75">Inscription rapide avec vérification par email.</p>
            </div>
            <div class="col-md-3 text-center">
                <div class="display-5 fw-bold mb-2 numero-etape">2</div>
                <h6 class="fw-bold">Stockez vos données</h6>
                <p class="small opacity-75">Ajoutez codes, documents et mots de passe dans votre coffre chiffré.</p>
            </div>
            <div class="col-md-3 text-center">
                <div class="display-5 fw-bold mb-2 numero-etape">3</div>
                <h6 class="fw-bold">Désignez vos bénéficiaires</h6>
                <p class="small opacity-75">Choisissez qui recevra quoi en cas de besoin.</p>
            </div>
            <div class="col-md-3 text-center">
                <div class="display-5 fw-bold mb-2 numero-etape">4</div>
                <h6 class="fw-bold">Vivez l'esprit tranquille</h6>
                <p class="small opacity-75">Vos données sont protégées et transmises automatiquement.</p>
            </div>
        </div>
    </div>
</div>

{# Section Sécurité #}
<div class="container py-5 my-5">
    <div class="row justify-content-center">
        <div class="col-lg-9 text-center">
            <h2 class="mb-5 display-6 fw-bold">Votre sécurité, notre priorité</h2>
            <div class="row g-4 text-start">
                <div class="col-md-6">
                    <p class="mb-3 fs-5">&#10003; Chiffrement AES-256-CBC du contenu</p>
                    <p class="mb-3 fs-5">&#10003; Mot de passe panique avec leurre</p>
                    <p class="mb-3 fs-5">&#10003; Alerte SOS aux contacts de confiance</p>
                </div>
                <div class="col-md-6">
                    <p class="mb-3 fs-5">&#10003; Mode vacances personnalisable</p>
                    <p class="mb-3 fs-5">&#10003; Logs d'audit traçabilité complète</p>
                    <p class="mb-3 fs-5">&#10003; Validation légale par un Notaire</p>
                </div>
            </div>
        </div>
    </div>
</div>


{% endblock %}