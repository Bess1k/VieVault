<header>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand fw-bold" href="{{ path('app_home') }}">
                <img src="{{ asset('images/logo.png') }}" alt="VieVault" height="35" class="me-2">
                VieVault
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a href="{{ path('app_home') }}" class="nav-link">Accueil</a>
                    </li>

                    {% if app.user %}
                        {# Menu visible uniquement pour les utilisateurs connectés #}
                        <li class="nav-item">
                            <a href="{{ path('app_profile') }}" class="nav-link">Mon profil</a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('app_dashboard') }}" class="nav-link">Tableau de bord</a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('app_vault') }}" class="nav-link">Mon coffre</a>
                        </li>
