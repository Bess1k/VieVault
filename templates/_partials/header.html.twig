                        <li class="nav-item">
                            <a href="{{ path('app_logout') }}" class="nav-link text-warning">Déconnexion</a>
                        </li>
                    {% else %}
                        {# Menu visible uniquement pour les visiteurs #}
                        <li class="nav-item">
                            <a href="{{ path('app_login') }}" class="nav-link">Connexion</a>
                        </li>
                        <li class="nav-item">
