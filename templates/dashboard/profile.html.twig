{% extends 'base.html.twig' %}

{% block title %}Mon profil{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="mb-4">
        <h1>Mon profil</h1>
        <p class="text-muted mb-0">Gérez vos informations personnelles et la sécurité de votre compte</p>
    </div>

    {# Section : Informations personnelles #}
    <div class="card card-white mb-4">
        <div class="card-body">
            {{ form_start(profileForm) }}
                <p class="text-uppercase text-muted small fw-bold mb-3">Informations personnelles</p>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(profileForm.lastname, 'Nom', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(profileForm.lastname, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(profileForm.lastname) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_label(profileForm.firstname, 'Prénom', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(profileForm.firstname, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(profileForm.firstname) }}
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_label(profileForm.email, 'Adresse e-mail', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(profileForm.email, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(profileForm.email) }}
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(profileForm.birthPlace, 'Lieu de naissance', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(profileForm.birthPlace, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(profileForm.birthPlace) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Date de naissance</label>
                        <input type="text" class="form-control" value="{{ user.birthDate|date('d/m/Y') }}" disabled>
                        <p class="text-muted small mt-1 mb-0">Non modifiable </p>
                    </div>
                </div>

                <p class="text-uppercase text-muted small fw-bold mb-3 mt-4">Changer le mot de passe</p>
                <p class="text-muted small mb-3">Laissez vide pour conserver votre mot de passe actuel.</p>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(profileForm.plainPassword.first, 'Nouveau mot de passe', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(profileForm.plainPassword.first, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(profileForm.plainPassword.first) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_label(profileForm.plainPassword.second, 'Confirmer le mot de passe', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(profileForm.plainPassword.second, {'attr': {'class': 'form-control'}}) }}
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3 pt-3 border-top">
                    {{ form_widget(profileForm.submit, {'attr': {'class': 'btn btn-primary'}}) }}
                    <a href="{{ path('app_dashboard') }}" class="btn btn-outline-secondary">Retour</a>
                </div>
            {{ form_end(profileForm) }}
        </div>
    </div>

    {# Section : Sécurité #}
    <div class="card card-white mb-4">
        <div class="card-body">
            <p class="text-uppercase text-muted small fw-bold mb-3">Sécurité</p>
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <p class="mb-1 fw-bold">Mot de passe panique</p>
                    <p class="text-muted small mb-0">Configurez un mot de passe d'urgence pour activer le mode leurre</p>
                </div>
                <a href="{{ path('app_panic_password') }}" class="btn btn-outline-danger btn-sm">Configurer</a>
            </div>
        </div>
    </div>

    {# Section : Zone dangereuse #}
    <div class="card mb-4 dangerzone">
        <div class="card-body">
            <p class="text-uppercase small fw-bold mb-3 text-danger">Zone dangereuse</p>
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <p class="mb-1 fw-bold">Supprimer mon compte</p>
                    <p class="text-muted small mb-0">Cette action est définitive. Toutes vos données seront effacées.</p>
                </div>
                <form method="post" action="{{ path('app_profile_delete') }}" onsubmit="return confirm('Êtes-vous absolument sûr ? Cette action est irréversible.');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_account') }}">
                    <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}