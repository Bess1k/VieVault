{% extends 'base.html.twig' %}

{% block title %}Mon profil{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="mb-4">
        <h1>Mon profil</h1>
        <p class="text-muted mb-0">Gérez vos informations personnelles et la sécurité de votre compte</p>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {# Section : Informations personnelles #}
    <div class="card card-white mb-4">
        <div class="card-body">
            <form method="post">
                <p class="text-uppercase text-muted small fw-bold mb-3">Informations personnelles</p>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="lastname" class="form-label">Nom</label>
                        <input type="text" name="lastname" id="lastname" class="form-control" value="{{ user.lastname }}" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="firstname" class="form-label">Prénom</label>
                        <input type="text" name="firstname" id="firstname" class="form-control" value="{{ user.firstname }}" required>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="email" class="form-label">Adresse e-mail</label>
                    <input type="email" name="email" id="email" class="form-control" value="{{ user.email }}" required>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="birthPlace" class="form-label">Lieu de naissance</label>
                        <input type="text" name="birthPlace" id="birthPlace" class="form-control" value="{{ user.birthPlace }}" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Date de naissance</label>
                        <input type="text" class="form-control" value="{{ user.birthDate|date('d/m/Y') }}" disabled>
                        <p class="text-muted small mt-1 mb-0">Non modifiable (vérification d'identité)</p>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3 pt-3 border-top">
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                    <a href="{{ path('app_dashboard') }}" class="btn btn-outline-secondary">Retour</a>
                </div>
            </form>
        </div>
    </div>

    {# Section : Sécurité #}
    <div class="card card-white mb-4">
        <div class="card-body">
            <p class="text-uppercase text-muted small fw-bold mb-3" >Sécurité</p>
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <p class="mb-1 fw-bold">Mot de passe panique</p>
                    <p class="text-muted small mb-0">Configurez un mot de passe d'urgence pour activer le mode leurre</p>
                </div>
                <a href="{{ path('app_panic_password') }}" class="btn btn-outline-danger btn-sm">Configurer</a>
            </div>
        </div>
    </div>

    {# Section : Zone dangereuse #}
    <div class="card mb-4 dangerzone">
        <div class="card-body">
            <p class="text-uppercase small fw-bold mb-3 text-danger" >Zone dangereuse</p>
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <p class="mb-1 fw-bold">Supprimer mon compte</p>
                    <p class="text-muted small mb-0">Cette action est définitive. Toutes vos données seront effacées.</p>
                </div>
                <form method="post" action="{{ path('app_profile_delete') }}" onsubmit="return confirm('Êtes-vous absolument sûr ? Cette action est irréversible.');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_account') }}">
                    <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}