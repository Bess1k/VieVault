{% extends 'base.html.twig' %}

{% block title %}Configurer le mot de passe panique{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Configurer le mot de passe panique</h1>
    <p class="text-muted">
        Le mot de passe panique vous permet de vous connecter en mode leurre.
        Si vous êtes forcé de vous connecter, utilisez ce mot de passe :
        le système affichera un faux tableau de bord.
    </p>

    <form method="post">
        <div class="mb-3">
            <label for="panic_password" class="form-label">Nouveau mot de passe panique</label>
            <input type="password" name="panic_password" id="panic_password" class="form-control" required minlength="6">
        </div>
        <button type="submit" class="btn btn-danger">Enregistrer</button>
        <a href="{{ path('app_dashboard') }}" class="btn btn-secondary">Annuler</a>
    </form>
</div>
{% endblock %}