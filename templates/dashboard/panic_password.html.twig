{% extends 'base.html.twig' %}

{% block title %}Configurer le mot de passe panique{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Configurer le mot de passe panique</h1>
    <p class="text-muted">
        Le mot de passe panique vous permet de vous connecter en mode leurre.
        Si vous êtes forcé de vous connecter, utilisez ce mot de passe :
        le système affichera un faux tableau de bord et enverra une alerte 
        silencieuse au contact de confiance.
    </p>

    <form method="post">
        <div class="mb-3">
            <label for="panic_password" class="form-label">Mot de passe panique</label>
            <input type="password" name="panic_password" id="panic_password" class="form-control" required minlength="6">
        </div>
        <div class="mb-3">
            <label for="emergency_email" class="form-label">Email du contact de confiance (SOS)</label>
            <input type="email" name="emergency_email" id="emergency_email" class="form-control" 
                   value="{{ app.user.emergencyEmail ?? '' }}" required>
            <div class="form-text">Cette personne recevra une alerte si le mot de passe panique est utilisé.</div>
        </div>
        <button type="submit" class="btn btn-danger">Enregistrer</button>
        <a href="{{ path('app_dashboard') }}" class="btn btn-secondary">Annuler</a>
    </form>
</div>
{% endblock %}