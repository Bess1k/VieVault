{% extends 'base.html.twig' %}

{% block title %}Vérification requise{% endblock %}

{% block body %}
<div class="container mt-5 text-center">
    <h1>Vérification requise</h1>
    <p class="text-muted">Veuillez vérifier votre adresse email avant d'accéder à votre coffre.</p>
    <p>Un email de confirmation a été envoyé à votre adresse. Cliquez sur le lien pour activer votre compte.</p>
    <a href="{{ path('app_logout') }}" class="btn btn-secondary mt-3">Déconnexion</a>
</div>
{% endblock %}