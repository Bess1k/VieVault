{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
<div class="container mt-4">
    {# En-tête du dashboard #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>Bienvenue {{ user.firstname }}</h1>
            <p class="text-muted mb-0">Votre espace personnel VieVault</p>
        </div>        
    </div>

    {# Messages flash #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <div class="row g-4">
        {# Carte : Éléments du coffre #}
        <div class="col-md-4">
            <div class="card card-hover h-100">
                <div class="card-body text-center">
                    <img src="{{ asset('images/coffre.png') }}" alt="Coffre" height="100" class="mb-1">
                    <h5 class="card-title text-uppercase">Mon coffre</h5>
                    <p class="display-6 fw-bold" style="color: #0d6efd;">{{ vaultElements|length }}</p>
                    <p class="text-muted">élément(s) stocké(s)</p>
                    <a href="{{ path('app_vault') }}" class="btn btn-primary btn-sm">Gérer mon coffre</a>
                </div>
            </div>
        </div>

        {# Carte : Bénéficiaires #}
        <div class="col-md-4">
            <div class="card card-hover h-100">
                <div class="card-body text-center">                    
                    <img src="{{ asset('images/beneficiaires.png') }}" alt="Bénéficiaires" height="100" class="mb-1">
                    <h5 class="card-title text-uppercase">Mes bénéficiaires</h5>
                    <p class="display-6 fw-bold" style="color: #0d6efd;">{{ beneficiaries|length }}</p>
                    <p class="text-muted">bénéficiaire(s) désigné(s)</p>
                    <a href="{{ path('app_beneficiary') }}" class="btn btn-primary btn-sm">Gérer mes bénéficiaires</a>
                </div>
            </div>
        </div>

        {# Carte : Mode vacances #}
        <div class="col-md-4">
            <div class="card card-hover h-100">
                <div class="card-body text-center">
                    <img src="{{ asset('images/vacance.png') }}" alt="Pause" height="100" class="mb-1">
                    <h5 class="card-title text-uppercase">Mode vacances</h5>
                    {% if user.isPaused %}
                        <span class="badge bg-warning mb-2">Activé</span>
                        {% if user.pauseUntil %}
                            <p class="text-muted">Jusqu'au {{ user.pauseUntil|date('d/m/Y') }}</p>
                        {% endif %}
                        <form method="post" action="{{ path('app_vacation_toggle') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('vacation') }}">
                            <button type="submit" class="btn btn-sm btn-outline-success mb-2">Désactiver</button>
                        </form>
                    {% else %}
                        <span class="badge bg-secondary mb-2">Désactivé</span>
                        <form method="post" action="{{ path('app_vacation_toggle') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('vacation') }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger mt-5">Activer (180 jours)</button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Carte : Mot de passe panique - visible uniquement en mode normal #}
        {% if not app.session.get('panic_mode') %}
        <div class="col-md-4">
            <div class="card card-hover h-100">
                <div class="card-body text-center">
                    <div class="display-4 mb-3">&#128680;</div>
                    <h5 class="card-title text-uppercase">Mot de passe panique</h5>
                    {% if user.panicPasswordHash %}
                        <span class="badge bg-success mb-2">Configuré</span>
                    {% else %}
                        <span class="badge bg-secondary mb-2">Non configuré</span>
                    {% endif %}
                    <p class="text-muted">Protection d'urgence</p>
                    <a href="{{ path('app_panic_password') }}" class="btn btn-sm btn-outline-danger">Configurer</a>
                </div>
            </div>
        </div>
        {% endif %}

        {# Carte : Logs d'audit #}
        <div class="col-md-4">
            <div class="card card-hover h-100">
                <div class="card-body text-center">
                    <div class="display-4 mb-3">&#128203;</div>
                    <h5 class="card-title text-uppercase">Logs d'audit</h5>
                    <p class="text-muted">Historique de toutes vos actions</p>
                    <a href="{{ path('app_audit_logs') }}" class="btn btn-sm btn-outline-secondary">Consulter</a>
                </div>
            </div>
        </div>

        {# Carte : Mon profil #}
        <div class="col-md-4">
            <div class="card card-hover h-100">
                <div class="card-body text-center">
                    <div class="display-4 mb-3">&#128100;</div>
                    <h5 class="card-title text-uppercase">Mon profil</h5>
                    <p class="text-muted">{{ user.email }}</p>
                    <a href="{{ path('app_profile') }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}