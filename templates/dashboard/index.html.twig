{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Bienvenue, {{ user.firstname }} {{ user.lastname }}</h1>
    <p>Statut du compte : <span class="badge bg-success">{{ user.status }}</span></p>

     {# Affichage de messages #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <div class="row mt-4">
        {# Carte : Éléments du coffre #}
        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <h5 class="card-title">Mon coffre</h5>
                    <p class="display-6">{{ vaultElements|length }}</p>
                    <p class="text-muted">élément(s)</p>
                    <a href="{{ path('app_vault') }}" class="btn btn-primary btn-sm">Gérer</a>
                </div>
            </div>
        </div>

        {# Carte : Bénéficiaires #}
        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <h5 class="card-title">Mes bénéficiaires</h5>
                    <p class="display-6">{{ beneficiaries|length }}</p>
                    <p class="text-muted">bénéficiaire(s)</p>
                    <a href="{{ path('app_beneficiary') }}" class="btn btn-primary btn-sm">Gérer</a>
                </div>
            </div>
        </div>

        {# Carte : Mode vacances #}
        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <h5 class="card-title">Mode vacances</h5>
                    {% if user.isPaused %}
                        <span class="badge bg-warning mb-2">Activé</span>
                        {% if user.pauseUntil %}
                            <p class="text-muted">Jusqu'au {{ user.pauseUntil|date('d/m/Y') }}</p>
                        {% endif %}
                        <form method="post" action="{{ path('app_vacation_toggle') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('vacation') }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Désactiver</button>
                        </form>
                    {% else %}
                        <span class="badge bg-secondary mb-2">Désactivé</span>
                        <p class="text-muted"></p>
                        <form method="post" action="{{ path('app_vacation_toggle') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('vacation') }}">
                            <button type="submit" class="btn btn-sm btn-outline-success">Activer (180 jours)</button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Carte : Mot de passe panique - visible uniquement en mode normal #}
        {% if not app.session.get('panic_mode') %}
        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <h5 class="card-title">Mot de passe panique</h5>
                    {% if user.panicPasswordHash %}
                        <span class="badge bg-success mb-2">Configuré</span>
                    {% else %}
                        <span class="badge bg-secondary mb-2">Non configuré</span>
                    {% endif %}
                    <br>
                    <a href="{{ path('app_panic_password') }}" class="btn btn-sm btn-outline-danger">Configurer</a>
                </div>
            </div>
        </div>
        {% endif %}

        {# Carte : Logs d'audit #}
        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body text-center">
                    <h5 class="card-title">Logs d'audit</h5>
                    <p class="text-muted">Historique de vos actions</p>
                    <a href="{{ path('app_audit_logs') }}" class="btn btn-sm btn-outline-secondary">Consulter</a>
                </div>
            </div>
        </div>

</div>
{% endblock %}