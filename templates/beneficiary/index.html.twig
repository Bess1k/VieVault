{% extends 'base.html.twig' %}

{% block title %}Mes bénéficiaires{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>Mes bénéficiaires</h1>
            <p class="text-muted mb-0">{{ beneficiaries|length }} bénéficiaire(s) désigné(s)</p>
        </div>
        <a href="{{ path('app_beneficiary_new') }}" class="btn btn-primary">+ Ajouter un bénéficiaire</a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% if beneficiaries|length == 0 %}
        <div class="alert alert-info">
            Vous n'avez pas encore de bénéficiaire. Ajoutez-en un pour organiser votre héritage.
        </div>
    {% else %}
        <div class="row g-4">
            {% for b in beneficiaries %}
                <div class="col-md-4">
                    <div class="card card-hover card-white h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold" 
                                     style="width: 45px; height: 45px; background: #e8f0fe; color: #0d6efd; font-size: 16px;">
                                    {{ b.firstname|first }}{{ b.lastname|first }}
                                </div>
                                <div>
                                    <h5 class="mb-0 fw-bold">{{ b.firstname }} {{ b.lastname }}</h5>
                                    <p class="text-muted small mb-0">{{ b.email }}</p>
                                </div>
                            </div>

                            {% if b.vaultElements|length > 0 %}
                                <p class="small mb-1 text-muted">Éléments légués :</p>
                                <div class="mb-2">
                                    {% for el in b.vaultElements %}
                                        <span class="text-muted small border rounded px-2 py-1 me-1">{{ el.title }}</span>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <p class="small text-muted mb-2">Aucun élément légué</p>
                            {% endif %}
                        </div>
                        <div class="card-footer bg-transparent">
                            <a href="{{ path('app_beneficiary_edit', {id: b.id}) }}" class="small" style="color: #0d6efd;">Modifier</a>
                            <span class="text-muted mx-1">|</span>
                            <form method="post" action="{{ path('app_beneficiary_delete', {id: b.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer ce bénéficiaire ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ b.id) }}">
                                <button type="submit" class="btn btn-link btn-sm p-0 small text-danger text-decoration-none">Supprimer</button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}