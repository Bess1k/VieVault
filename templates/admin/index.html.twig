{% extends 'base.html.twig' %}

{% block title %}Administration{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Administration — Gestion des utilisateurs</h1>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Prénom</th>
                    <th>Email</th>
                    <th>Rôles</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr>
                        <td>{{ user.lastname }}</td>
                        <td>{{ user.firstname }}</td>
                        <td>{{ user.email }}</td>
                        <td>
                            {% for role in user.roles %}
                                {% if role == 'ROLE_ADMIN' %}
                                    <span class="badge bg-dark">Admin</span>
                                {% elseif role == 'ROLE_NOTAIRE' %}
                                    <span class="badge bg-info">Notaire</span>
                                {% elseif role == 'ROLE_USER' %}
                                    <span class="badge bg-secondary">Utilisateur</span>
                                {% endif %}
                            {% endfor %}
                        </td>
                        <td>                            
                            {% if user.isPaused %}
                                <span class="badge bg-info">En mode vacances</span>
                            {% elseif user.status == 'ACTIVE' %}
                                <span class="badge bg-success">Actif</span>
                            {% elseif user.status == 'INACTIVE' %}
                                <span class="badge bg-danger">Héritage déclenché</span>
                            {% endif %}                            
                        </td>
                        <td>
                            <form method="post" action="{{ path('app_admin_set_notaire', {id: user.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('role' ~ user.id) }}">
                                {% if 'ROLE_NOTAIRE' in user.roles %}
                                    <button type="submit" class="btn btn-sm btn-outline-warning">Retirer Notaire</button>
                                {% else %}
                                    <button type="submit" class="btn btn-sm btn-outline-info">Attribuer Notaire</button>
                                {% endif %}
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}